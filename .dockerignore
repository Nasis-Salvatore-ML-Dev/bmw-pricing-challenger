# BMW Pricing API - Docker Ignore File
# Exclude unnecessary files from Docker image

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
ENV/
tf_env_clean/

# Jupyter notebooks
notebooks/
*.ipynb
.ipynb_checkpoints/

# Data (except model)
data/raw/
data/processed/
data/outputs/

# Reports
reports/
logs/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Documentation
docs/
*.md
README.md

# Testing
tests/
*.test.py

# Config (except production)
config/dev/
config/staging/

# Scripts (except deployment)
scripts/data/
scripts/training/
scripts/monitoring/
scripts/testing/

# Other
local_docs/
infra/
.github/